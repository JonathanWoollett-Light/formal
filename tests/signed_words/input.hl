# Signed 32-bit (i32) arithmetic with negative values: store -100, 50, -25 into
# an [i32] array, read them back and prove the sum is -75 at compile time, then
# boot under qemu-riscv64 and exit 0. Exercises the value model's signed-word
# load/store/add paths the unsigned programs do not reach.
nums: global [i32]*3
t0 = &nums
t1 = -100
t0[0:4] = t1
t1 = 50
t0[4:8] = t1
t1 = -25
t0[8:12] = t1
a0 = t0[0:4]
a1 = t0[4:8]
a2 = t0[8:12]
a0 = a0 + a1
a0 = a0 + a2
a3 = -75
require a0 == a3
exit(0)
