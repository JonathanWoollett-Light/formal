# Binary search for 7 in the sorted array [1 3 5 7 9 11], proving it is found at
# index 3 at compile time. Standard lo/hi/mid search: mid = (lo+hi)/2, compare
# arr[mid] against the target, and narrow the half. The verifier follows the
# concrete search, so `require found == 3` is the proof. Boots and exits 0.
#
# Registers: a0 = lo, a1 = hi, a2 = mid, a3 = target, a4 = found, a5 = 4 (elem
# size), a6 = 2, t0 = &arr[mid], t1 = byte offset, t2 = arr[mid].
arr: thread [u32]*6
t0 = &arr
t1 = 1
t0[0:4] = t1
t1 = 3
t0[4:8] = t1
t1 = 5
t0[8:12] = t1
t1 = 7
t0[12:16] = t1
t1 = 9
t0[16:20] = t1
t1 = 11
t0[20:24] = t1

a3 = 7
a4 = 0
a5 = 4
a6 = 2
a0 = 0
a1 = 5
while a0 <= a1:
    a2 = a0 + a1
    a2 = a2 / a6
    t1 = a2 * a5
    t0 = &arr
    t0 = t0 + t1
    t2 = t0[0:4]
    if t2 == a3:
        a4 = a2
        a0 = a1 + 1
    if t2 < a3:
        a0 = a2 + 1
    if t2 > a3:
        a1 = a2 - 1

t3 = 3
require a4 == t3
exit(0)
