# Dot product of two signed i32 vectors: [-1 2 -3] . [4 -5 6] = -4 -10 -18 = -32,
# proven at compile time. Loads signed i32 pairs from memory, multiplies and
# accumulates -- exercising signed i32 multiply -- then boots under qemu-riscv64
# and exits 0.
#
# Registers: a0 = acc, a1 = i, a2 = n, a5 = 4 (elem size), t1 = byte offset,
#            t2/t3 = &x[i]/&y[i], a3/a4 = x[i]/y[i].
x: global [i32]*3
y: global [i32]*3
t0 = &x
t1 = -1
t0[0:4] = t1
t1 = 2
t0[4:8] = t1
t1 = -3
t0[8:12] = t1
t0 = &y
t1 = 4
t0[0:4] = t1
t1 = -5
t0[4:8] = t1
t1 = 6
t0[8:12] = t1

a0 = 0
a1 = 0
a2 = 3
a5 = 4
while a1 < a2:
    t1 = a1 * a5
    t2 = &x
    t2 = t2 + t1
    t3 = &y
    t3 = t3 + t1
    a3 = t2[0:4]
    a4 = t3[0:4]
    a3 = a3 * a4
    a0 = a0 + a3
    a1 = a1 + 1

a6 = -32
require a0 == a6
exit(0)
