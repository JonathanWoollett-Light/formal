# Signed 16-bit (i16) arithmetic with negatives, via 2-byte halfword load/store:
# store -1000, 500, -200 into an [i16] array, read them back and prove the sum
# is -700 at compile time. Boots under qemu-riscv64 and exits 0.
vals: global [i16]*3
t0 = &vals
t1 = -1000
t0[0:2] = t1
t1 = 500
t0[2:4] = t1
t1 = -200
t0[4:6] = t1
a0 = t0[0:2]
a1 = t0[2:4]
a2 = t0[4:6]
a0 = a0 + a1
a0 = a0 + a2
a3 = -700
require a0 == a3
exit(0)
