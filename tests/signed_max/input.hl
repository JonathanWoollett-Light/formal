# Maximum of an array of signed 32-bit values: max([-5 3 -1 -8 2]) = 3, proven
# at compile time. The running `if nums[i] > max` compares signed i32 values
# loaded from memory -- the signed-comparison path the unsigned sort/search do
# not reach. Boots under qemu-riscv64 and exits 0.
#
# Registers: a0 = max, a1 = i, a2 = n, a5 = 4 (elem size), t2 = &nums[i],
#            a3 = nums[i].
nums: global [i32]*5
t0 = &nums
t1 = -5
t0[0:4] = t1
t1 = 3
t0[4:8] = t1
t1 = -1
t0[8:12] = t1
t1 = -8
t0[12:16] = t1
t1 = 2
t0[16:20] = t1

a5 = 4
a0 = t0[0:4]
a1 = 1
a2 = 5
while a1 < a2:
    t1 = a1 * a5
    t2 = &nums
    t2 = t2 + t1
    a3 = t2[0:4]
    if a3 > a0:
        a0 = a3
    a1 = a1 + 1

t4 = 3
require a0 == t4
exit(0)
