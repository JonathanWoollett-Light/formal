# Runtime input the verifier cannot see: write a literal 12 into a declared
# region and read it back through a raw address. The raw-address load yields the
# full range, so the verifier treats n as unknown (it cannot constant-fold);
# at runtime the region holds 12. Then narrow n%4 in 0..3 and index a 4-element
# array safely -- provably in-bounds for *any* n.
section 0x80100000 0x80100008 rw
arr: thread [u32]*4
t0 = 0x80100000
t1 = 12
t0[0:4] = t1
a0 = t0[0:4]       # n: unknown to verifier, 12 at runtime
t2 = 4
a1 = a0 % t2       # n % 4 -> 0..3
t3 = &arr
t4 = a1 * t2       # byte offset 0..12
t5 = t3 + t4       # &arr[n%4]  (in bounds for any n)
a2 = 7
t5[0:4] = a2       # arr[n%4] = 7
exit(0)
