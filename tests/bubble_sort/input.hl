# Bubble sort of a small u32 array, with the sortedness of the result *proven*
# at compile time. The array starts [5 2 8 1 9 3]; after n-1 passes of adjacent
# swaps it is [1 2 3 5 8 9]. The final loop asserts `arr[k] <= arr[k+1]` for
# every adjacent pair with `require`, so a `Valid` outcome IS a proof the sort
# produced a sorted array (the same trick fannkuch-redux uses for its answer).
# The program then boots and exits 0.
#
# Indexed access is `&arr + k*4` (u32 elements), exercising the register-register
# multiply/add; the comparisons lower to `bge`/`blt` over u32 values loaded from
# memory.
#
# Registers: a1 = n (6), a2 = n-1 (5), a5 = 4 (element size), a0 = pass/k outer,
#            t0 = k, t1 = byte offset, t2 = &arr[k], a3/a4 = arr[k]/arr[k+1].

arr: thread [u32]*6

a1 = 6
a2 = 5
a5 = 4

# --- initialise the array: [5 2 8 1 9 3] ---
t0 = &arr
t1 = 5
t0[0:4] = t1
t1 = 2
t0[4:8] = t1
t1 = 8
t0[8:12] = t1
t1 = 1
t0[12:16] = t1
t1 = 9
t0[16:20] = t1
t1 = 3
t0[20:24] = t1

# --- sort: n passes of adjacent compare-and-swap ---
a0 = 0
while a0 < a1:
    t0 = 0
    while t0 < a2:
        t1 = t0 * a5
        t2 = &arr
        t2 = t2 + t1
        a3 = t2[0:4]
        a4 = t2[4:8]
        if a3 > a4:
            t2[0:4] = a4
            t2[4:8] = a3
        t0 = t0 + 1
    a0 = a0 + 1

# --- prove the result is sorted: arr[k] <= arr[k+1] for every adjacent pair ---
t0 = 0
while t0 < a2:
    t1 = t0 * a5
    t2 = &arr
    t2 = t2 + t1
    a3 = t2[0:4]
    a4 = t2[4:8]
    require a3 <= a4
    t0 = t0 + 1

exit(0)
