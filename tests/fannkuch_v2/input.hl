# fannkuch-redux V2: REAL parallel work-sharing across 2 harts, hosted Linux.
#
# Runs in **user mode** (qemu-riscv64): the hosted codegen spawns one OS thread
# per extra hart with `clone`, so the two harts run on two cores in parallel (not
# -smp round-robin) -- the fastest way to run it. Every hart computes a disjoint
# slice of the permutation space into its OWN per-hart `thread` arrays, and the
# partial results are combined lock-free. This is the optimal shape -- unlike a
# leader/worker split (one hart works, the rest park), the work is genuinely
# shared. It relies on per-hart thread-local storage (each hart's perm/work/cnt
# is a distinct copy), which `clone`'s CLONE_SETTLS gives each thread its own `tp`
# for; the original single-copy thread-local codegen could not express this.
#
# Work split (no enumeration of another hart's permutations):
#   The n! permutations form n contiguous BLOCKS under the fannkuch rotation
#   enumeration, indexed by the top odometer digit cnt[n-1]. Block c is the (n-1)!
#   permutations whose whole array has been rotated left c times; its first
#   permutation is [c, c+1, ..., n-1, 0, ..., c-1] (perm[j] = (c+j) % n), and the
#   block is walked by the ordinary next-permutation rotation BOUNDED to the lower
#   digits (a3 < n-1). Block c spans global indices [c*(n-1)!, (c+1)*(n-1)!); since
#   (n-1)! is even for n >= 3, every block starts at global parity 0, so a hart's
#   per-block checksums (local parity also starting at 0) simply ADD to the global
#   checksum. Each hart h (rank claimed via amoadd) takes blocks h, h+2, h+4, ...
#   (2-hart stride; 3 harts is verification-infeasible).
#
# Combine (lock-free): each hart writes its partial checksum to a per-rank slot and
# atomic-maxes (amomax) its partial max-flips into a shared word, then bumps a done
# counter; the last finisher sums the checksum slots, reads the global max, writes
# the result with the std `print` (Linux `write`), then every thread exits. The
# max uses amomax (not a finisher compare-and-select) because at the small verified
# n the two partials are equal, so a compare branch would be pruned by
# remove_branches and the runtime n would lose the larger value.
#
# n is read at runtime (= 12) but the verifier is blind to it (forget) and an
# assume narrows it to 3 so verification is bounded.

# Output uses the std `print` (Linux `write` syscall), so the program is a hosted
# program with no UART poking; the std `print` is polymorphic over an integer and
# a string, exactly what the result line needs.

# shared globals (zero-init .bss)
rank_counter: global u32
done_counter: global u32
cs_slots: global [u32]*2
max_global: global u32

# per-hart thread-local state (a distinct copy per hart, via per-hart TLS)
perm: thread [u32]*16
work: thread [u32]*16
cnt: thread [u32]*16
myrank: thread u32
blockc: thread u32

# n: runtime = 12, verifier-blind (forget), narrowed to 3 (assume).
a2 = 12
forget a2
assume:
    a2 = 3

# full-init perm[i]=i, cnt=0, work=0 over all 12 (literal bound) so the dead-data
# compaction keeps the arrays full-sized for the runtime n.
t0 = &perm
t1 = 0
t3 = 12
while t1 != t3:
    t0[0:4] = t1
    t0 = t0 + 4
    t1 = t1 + 1
t0 = &cnt
t1 = 0
t2 = 0
while t1 != t3:
    t0[0:4] = t2
    t0 = t0 + 4
    t1 = t1 + 1
t0 = &work
t1 = 0
while t1 != t3:
    t0[0:4] = t2
    t0 = t0 + 4
    t1 = t1 + 1

# claim a unique rank h via an atomic fetch-add on the zero-init counter.
t0 = &rank_counter
t1 = 1
asm:
    amoadd.w a3, t1, (t0)
# remember the rank (for the slot index) and seed the first block c = h.
t0 = &myrank
t0[0:4] = a3
t0 = &blockc
t0[0:4] = a3

# partial accumulators (this hart's contribution across its blocks).
a5 = 0
a6 = 0

# ===== block loop: for c = h, h+2, ... while c < n =====
t0 = &blockc
t0 = t0[0:4]
while t0 < a2:
    # --- build the block's start permutation: perm[j] = (c + j) % n ---
    t1 = &blockc
    t1 = t1[0:4]
    t0 = &perm
    t2 = 0
    while t2 != a2:
        t3 = t1 + t2
        t4 = t3 % a2
        t0[0:4] = t4
        t0 = t0 + 4
        t2 = t2 + 1

    # --- reset the odometer cnt[i] = 0 ---
    t0 = &cnt
    t2 = 0
    t3 = 0
    while t2 != a2:
        t0[0:4] = t3
        t0 = t0 + 4
        t2 = t2 + 1

    # the block starts at global parity 0.
    a7 = 0

    # --- walk the block's (n-1)! permutations ---
    a4 = 0
    while a4 == 0:
        # copy perm -> work
        t0 = &perm
        t1 = &work
        t2 = 0
        while t2 != a2:
            t4 = t0[0:4]
            t1[0:4] = t4
            t0 = t0 + 4
            t1 = t1 + 4
            t2 = t2 + 1

        # count flips on work
        a0 = 0
        t0 = &work
        t1 = t0[0:4]
        while t1 != 0:
            # &work[k] directly (k = t1); t4 holds the stride (4) for one multiply,
            # then becomes the reverse counter.
            t2 = &work
            t4 = 4
            t3 = t1 * t4
            t3 = t2 + t3
            t4 = 0
            t5 = t1 + 0
            while t4 < t5:
                t1 = t2[0:4]
                a1 = t3[0:4]
                t2[0:4] = a1
                t3[0:4] = t1
                t2 = t2 + 4
                t3 = t3 - 4
                t4 = t4 + 1
                t5 = t5 - 1
            a0 = a0 + 1
            t1 = t0[0:4]

        # max flips
        if a0 > a5:
            a5 = a0 + 0

        # checksum += (parity == 0 ? flips : -flips)
        t0 = a0 + 0
        if a7 == 0:
            while t0 != 0:
                a6 = a6 + 1
                t0 = t0 - 1
        if a7 != 0:
            while t0 != 0:
                a6 = a6 - 1
                t0 = t0 - 1

        # toggle parity
        t0 = a7 + 0
        a7 = 1
        if t0 != 0:
            a7 = 0

        # next permutation, BOUNDED to the lower digits (a3 < n-1) so the walk
        # stays inside this block (the top digit cnt[n-1] is never carried).
        a1 = a2 - 1
        a4 = 1
        a3 = 1
        while a3 < a1:
            t0 = &perm
            t1 = t0[0:4]
            t2 = &perm
            t3 = 0
            while t3 < a3:
                t4 = t2[4:8]
                t2[0:4] = t4
                t2 = t2 + 4
                t3 = t3 + 1
            t2[0:4] = t1
            t2 = &cnt
            t3 = 0
            while t3 < a3:
                t2 = t2 + 4
                t3 = t3 + 1
            t4 = t2[0:4]
            t4 = t4 + 1
            t2[0:4] = t4
            t5 = 1
            if t4 <= a3:
                a4 = 0
                a3 = a1 + 0
                t5 = 0
            if t5 != 0:
                t3 = 0
                t2[0:4] = t3
                a3 = a3 + 1

    # --- advance to this hart's next block: c += 2 ---
    t0 = &blockc
    t1 = t0[0:4]
    t1 = t1 + 2
    t0[0:4] = t1
    t0 = t1

# ===== combine: per-rank checksum slot + atomic-max the flip count =====
t0 = &myrank
t1 = t0[0:4]
t2 = 4
t3 = t1 * t2
t0 = &cs_slots
t0 = t0 + t3
t0[0:4] = a6
# atomically max this hart's partial into the global max: a lock-free reduction.
# amomax is a SINGLE instruction, so -- unlike a compare-and-select max in the
# finisher -- there is no branch for remove_branches to specialise away at the
# small verified n (where the two harts' partials happen to be equal).
t0 = &max_global
asm:
    amomax.w t1, a5, (t0)

# ===== finisher detection: the last hart combines and outputs =====
# Release fence: make this hart's slot writes globally visible BEFORE it bumps the
# done counter, so the finisher (which observes the bump) is guaranteed to see them.
# The verifier explores all interleavings (SC), but QEMU MTTCG is weakly ordered.
t0 = &done_counter
t1 = 1
asm:
    fence rw, rw
    amoadd.w t2, t1, (t0)
a0 = 1
if t2 == a0:
    # Acquire fence: order the done-counter read before the slot reads below.
    asm:
        fence rw, rw
    # total checksum = cs_slots[0] + cs_slots[1]
    t0 = &cs_slots
    a5 = t0[0:4]
    t0 = t0 + 4
    a6 = t0[0:4]
    a5 = a5 + a6
    # total max flips: read the global the harts accumulated with amomax. No
    # combine, no branch -- the verify-small/run-large branch hazard is gone.
    t0 = &max_global
    a6 = t0[0:4]
    # output "<checksum>\nPfannkuchen(<n>) = <maxflips>\n" (save n; `print`
    # clobbers a0-a2/t0-t2/t5 but preserves a3/a5/a6 between calls).
    a3 = a2 + 0
    print(a5)
    print("\nPfannkuchen(")
    print(a3)
    print(") = ")
    print(a6)
    print("\n")

# every hart converges here; `unreachable` ends its thread (the finisher has
# already printed), so the process exits once the last thread is done.
unreachable
