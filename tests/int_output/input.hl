# Print the integer 42 to stdout by digit extraction (div/rem), then the Linux
# write syscall. Digits are written into a buffer from the back; the count is
# tracked so the right slice is written. (Assumes a positive value.)
buf: thread [u8]*20
t0 = &buf
t0 = t0 + 20        # one past the end of the buffer
a0 = 42             # the integer to print
t5 = a0 + 0         # working copy
t1 = 10
a2 = 0              # digit count
while t5 != 0:
    t2 = t5 % t1    # ones digit
    t5 = t5 / t1    # shift right one decimal place
    t2 = t2 + 48    # 0..9 -> '0'..'9'
    t0 = t0 - 1     # grow the number leftwards
    t0[0:1] = t2    # store the digit
    a2 = a2 + 1
a1 = t0 + 0         # start of the digits
a0 = 1              # fd = stdout
a7 = 64             # write(2)
asm:
    ecall
exit(0)
