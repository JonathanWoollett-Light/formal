# Difference array: diff[i] = arr[i+1] - arr[i], a standard technique (range
# updates, discrete derivatives). For arr = [10 7 12 4] the diffs are [-3 5 -8],
# and by telescoping their sum equals arr[3] - arr[0] = -6. The verifier computes
# the whole thing over concrete signed values, so `require sum == -6` is the
# proof. Boots under qemu-riscv64 and exits 0.
#
# Registers: a0 = i, a1 = n-1, a2 = running sum, a5 = 4 (elem size),
#            t2 = &arr[i], a3/a4 = arr[i]/arr[i+1], t3 = &diff[i].
arr: global [i32]*4
diff: global [i32]*3
t0 = &arr
t1 = 10
t0[0:4] = t1
t1 = 7
t0[4:8] = t1
t1 = 12
t0[8:12] = t1
t1 = 4
t0[12:16] = t1

a5 = 4
a0 = 0
a1 = 3
a2 = 0
while a0 < a1:
    t1 = a0 * a5
    t2 = &arr
    t2 = t2 + t1
    a3 = t2[0:4]
    a4 = t2[4:8]
    a4 = a4 - a3
    t3 = &diff
    t3 = t3 + t1
    t3[0:4] = a4
    a2 = a2 + a4
    a0 = a0 + 1

a6 = -6
require a2 == a6
exit(0)
