# assume: makes a runtime-unknown n tractable for the verifier by narrowing it to
# a concrete representative (here 5), so the loops are determinate and terminate.
# The block is verified but NOT emitted, so the runtime keeps n = 12 and fills
# arr[0..12]; the verifier proved the fill is memory-safe for n = 5 (a subset).
section 0x80100000 0x80100008 rw
arr: thread [u32]*16
t0 = 0x80100000
t1 = 12
t0[0:4] = t1
a0 = t0[0:4]        # n: unknown to verifier, 12 at runtime
assume:
    a0 = 5          # verifier-only: explore the n = 5 case (dropped from the binary)
a2 = 0              # i
while a2 != a0:
    t3 = 4
    t4 = a2 * t3
    t5 = &arr
    t5 = t5 + t4    # &arr[i]  (i concrete each iteration)
    t5[0:4] = a2    # arr[i] = i
    a2 = a2 + 1
exit(0)
